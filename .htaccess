RewriteEngine On

# Autoriser les requêtes CORS preflight (OPTIONS)
RewriteCond %{REQUEST_METHOD} OPTIONS
RewriteRule ^(.*)$ $1 [R=200,L]

# Rediriger toutes les requêtes (sauf si elles pointent vers un fichier physique) vers index.php
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^(.*)$ index.php [QSA,L]
